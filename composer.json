{
	"name": "detain/zip-zapper",
	"type": "library",
	"description": "Validates Zip\/Postal Codes for any country and provides each country's localized name for their version of the Zip\/Postal code (CEP, PLZ, PIN code, Eircode, NPA, CAP, ZIP code, etc.).",
	"keywords": [
		"postcode",
		"zip",
		"zipcode",
		"eircode",
		"postal code",
		"zip code",
		"validator",
		"cap",
		"cep",
		"npa",
		"pin code",
		"plz",
		"postal expedition code",
		"postal addressing code",
		"numero postal d'acheminement",
		"postal index number",
		"postal routing number",
		"zone improvement plan"
	],
	"homepage": "https:\/\/detain.github.io\/zip-zapper",
	"license": "MIT",
	"authors": [
		{
			"name": "Joe Huss",
			"email": "detain@interserver.net"
		}
	],
	"autoload": {
		"psr-4": {
			"Detain\\ZipZapper\\": "src/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"Detain\\Tests\\ZipZapper\\": "tests/Detain/Tests/ZipZapper/"
		}
	},
	"require": {
		"php": ">=7.2"
	},
	"require-dev": {
		"phpunit/phpunit": "^9.6"
	},
	"scripts": {
		"test": "phpunit tests/ -v"
	},
	"extra": {
		"branch-alias": {
			"dev-master": "1.1.x-dev"
		}
	}
}
